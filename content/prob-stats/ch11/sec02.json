{
  "id": "prob-stats-ch11-sec02",
  "title": "The ANOVA Table and F-Test",
  "chapter": 11,
  "section": 2,
  "book": "prob-stats",
  "epigraph": {
    "text": "A wise man scales the city of the mighty and brings down the stronghold in which they trust.",
    "reference": "Proverbs 21:22",
    "quote": "The ANOVA table organizes the decomposition of variation into its sources.",
    "quoteAuthor": "George W. Snedecor"
  },
  "content": [
    {
      "type": "paragraph",
      "text": "The calculations of ANOVA are organized in the ANOVA table."
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Partitioning Variation"
    },
    {
      "type": "paragraph",
      "text": "{Sum of Squares Decomposition}"
    },
    {
      "type": "paragraph",
      "text": "\\[\n SST = SSB + SSW\n\\]\nwhere:"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        "$SST = \\sum\\sum(x_{ij} - \\bar{x}_{..})^2$ (Total sum of squares)",
        "$SSB = \\sum n_i(\\bar{x}_i - \\bar{x}_{..})^2$ (Between-groups SS)",
        "$SSW = \\sum\\sum(x_{ij} - \\bar{x}_i)^2$ (Within-groups SS)"
      ]
    },
    {
      "type": "paragraph",
      "text": "atlasdefinition"
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Mean Squares and the F Statistic"
    },
    {
      "type": "paragraph",
      "text": "\\[\n MSB = \\frac{SSB}{k-1} \\qquad MSW = \\frac{SSW}{N-k}\n\\]"
    },
    {
      "type": "theorem",
      "id": "theorem-11.1",
      "number": "11.1",
      "title": "F-Test for ANOVA",
      "content": "\\[\n F = \\frac{MSB}{MSW}\n\\]\nUnder $H_0$, $F \\sim F_{k-1, N-k}$.\n\nReject $H_0$ if $F$ is large (right-tail test).",
      "label": "Theorem"
    },
    {
      "type": "heading",
      "level": 2,
      "text": "The ANOVA Table"
    },
    {
      "type": "table",
      "headers": [
        "**Source**",
        "**SS**",
        "**df**",
        "**MS**",
        "**F**"
      ],
      "rows": [
        [
          "Between",
          "$SSB$",
          "$k-1$",
          "$MSB$",
          "$F = MSB/MSW$"
        ],
        [
          "Within",
          "$SSW$",
          "$N-k$",
          "$MSW$",
          ""
        ],
        [
          "Total",
          "$SST$",
          "$N-1$",
          "",
          ""
        ]
      ],
      "alignment": [
        "left",
        "center",
        "center",
        "center",
        "center"
      ]
    },
    {
      "type": "example",
      "id": "example-11.1",
      "number": "11.1",
      "title": "Reading an ANOVA Table",
      "problem": "Given: $SSB = 120$, $SSW = 180$, $k = 4$ groups, $N = 40$ observations.",
      "solution": "$df_B = 3$, $df_W = 36$.\n\n$MSB = 120/3 = 40$, $MSW = 180/36 = 5$.\n\n$F = 40/5 = 8$.\n\nFrom $F_{3,36}$ table, $p < 0.001$. Reject $H_0$."
    }
  ]
}