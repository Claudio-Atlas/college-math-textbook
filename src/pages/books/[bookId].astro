---
export const prerender = false;
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { BookLandingPage } from '../../components/catalog/BookLandingPage';
import { getBookLanding } from '../../lib/books';

const { bookId } = Astro.params;
const book = getBookLanding(bookId as string);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={book ? `${book.title} — ${book.description}` : 'Book not found'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{book ? `${book.title} | Meridian Press` : 'Book Not Found'}</title>
    <ClientRouter />
    
    <!-- Fonts loaded via global.css (Inter + Source Serif 4) -->
  </head>
  <body>
    {book && book.chapters && book.chapters.length > 0 ? (
      <BookLandingPage book={book} client:only="react" />
    ) : book ? (
      <div class="min-h-screen flex items-center justify-center" style="background: var(--ax-bg); color: var(--ax-text);">
        <div class="text-center">
          <div class="mb-6">
            <span class="inline-block px-4 py-2 rounded-full text-lg font-medium" style="background: var(--ax-ex-bg); color: var(--ax-ex-accent);">
              Coming Soon
            </span>
          </div>
          <h1 class="text-3xl font-bold mb-4" style="color: var(--ax-text);">{book.title}</h1>
          <p class="mb-8 max-w-md mx-auto" style="color: var(--ax-text-secondary);">
            We're putting the finishing touches on this textbook. Check back soon.
          </p>
          <a href="/" class="inline-flex items-center px-6 py-3 text-white rounded-lg transition-colors" style="background: var(--ax-violet);">
            ← Back to Catalog
          </a>
        </div>
      </div>
    ) : (
      <div class="min-h-screen flex items-center justify-center" style="background: var(--ax-bg); color: var(--ax-text);">
        <div class="text-center">
          <h1 class="text-2xl font-bold mb-4" style="color: var(--ax-text);">Book Not Found</h1>
          <a href="/" class="hover:underline" style="color: var(--ax-violet);">← Back to Catalog</a>
        </div>
      </div>
    )}
  </body>
</html>
