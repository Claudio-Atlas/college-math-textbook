---
export const prerender = false;
import '../../styles/global.css';
import { BookLandingPage } from '../../components/catalog/BookLandingPage';
import { getBookLanding } from '../../lib/books';

const { bookId } = Astro.params;
const book = getBookLanding(bookId as string);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={book ? `${book.title} — ${book.description}` : 'Book not found'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{book ? `${book.title} | Meridian Press` : 'Book Not Found'}</title>
    
    <!-- Fonts loaded via global.css (Inter + Source Serif 4) -->
  </head>
  <body>
    {book && book.chapters && book.chapters.length > 0 ? (
      <BookLandingPage book={book} client:only="react" />
    ) : book ? (
      <div class="min-h-screen bg-gray-50 flex items-center justify-center">
        <div class="text-center">
          <div class="mb-6">
            <span class="inline-block bg-amber-100 text-amber-700 px-4 py-2 rounded-full text-lg font-medium">
              Coming Soon
            </span>
          </div>
          <h1 class="text-3xl font-bold text-gray-900 mb-4">{book.title}</h1>
          <p class="text-gray-600 mb-8 max-w-md mx-auto">
            We're putting the finishing touches on this textbook. Check back soon.
          </p>
          <a href="/" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
            ← Back to Catalog
          </a>
        </div>
      </div>
    ) : (
      <div class="min-h-screen bg-gray-50 flex items-center justify-center">
        <div class="text-center">
          <h1 class="text-2xl font-bold text-gray-900 mb-4">Book Not Found</h1>
          <a href="/" class="text-blue-600 hover:text-blue-800">← Back to Catalog</a>
        </div>
      </div>
    )}
  </body>
</html>
