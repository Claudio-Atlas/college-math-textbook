---
export const prerender = false;
import '../../styles/global.css';
import { BookDetail } from '../../components/catalog/BookDetail';
import { BookLandingPage } from '../../components/catalog/BookLandingPage';
import { getBookLanding } from '../../lib/books';

const { bookId } = Astro.params;

// Map catalog IDs to actual content IDs (for reader preview)
const BOOK_ID_MAP: Record<string, string> = {
  'calculus-vol1': 'vol1',
  'calculus-vol2': 'vol2',
  'calculus-vol3': 'vol3',
};

// Books available for full reader preview
const AVAILABLE_BOOKS: string[] = [
  // 'calculus-vol1',
];

const contentId = BOOK_ID_MAP[bookId as string] || bookId;
const isAvailable = AVAILABLE_BOOKS.includes(bookId as string);

// Check if we have a landing page for this book
const landing = getBookLanding(bookId as string);

let book;
let notFound = false;

if (isAvailable) {
  try {
    const bookModule = await import(`../../../content/${contentId}/book.json`);
    book = bookModule.default;
  } catch (e) {
    notFound = true;
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={landing ? `${landing.title} — ${landing.description}` : book ? `${book.title} - Mathematics Textbook` : 'Book not found'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{landing ? `${landing.title} — ${landing.subtitle || ''}` : book ? book.title : 'Book Not Found'}</title>
    
    <!-- Fonts loaded via global.css (Inter + Source Serif 4) -->
  </head>
  <body>
    {landing ? (
      <!-- Landing page with description, TOC, Meet the Author -->
      <BookLandingPage book={landing} client:only="react" />
    ) : isAvailable && book ? (
      <!-- Full reader preview -->
      <BookDetail book={book} bookId={contentId} client:only="react" />
    ) : notFound ? (
      <div class="min-h-screen bg-gray-50 flex items-center justify-center">
        <div class="text-center">
          <h1 class="text-2xl font-bold text-gray-900 mb-4">Book Not Found</h1>
          <a href="/" class="text-blue-600 hover:text-blue-800">
            ← Back to Catalog
          </a>
        </div>
      </div>
    ) : (
      <div class="min-h-screen bg-gray-50 flex items-center justify-center">
        <div class="text-center">
          <div class="mb-6">
            <span class="inline-block bg-amber-100 text-amber-700 px-4 py-2 rounded-full text-lg font-medium">
              Coming Soon
            </span>
          </div>
          <h1 class="text-3xl font-bold text-gray-900 mb-4">This textbook is not yet available</h1>
          <p class="text-gray-600 mb-8 max-w-md mx-auto">
            We're putting the finishing touches on this textbook. Check back soon for the full preview.
          </p>
          <a href="/" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
            ← Back to Catalog
          </a>
        </div>
      </div>
    )}
  </body>
</html>
