---
export const prerender = false;
import '../../styles/global.css';
import { BookDetail } from '../../components/catalog/BookDetail';

const { bookId } = Astro.params;

// Map catalog IDs to actual content IDs
const BOOK_ID_MAP: Record<string, string> = {
  'calculus-vol1': 'vol1',
  'calculus-vol2': 'vol2',
  'calculus-vol3': 'vol3',
};

// Books currently available for preview
// Set to empty array to disable all previews, or list specific IDs
const AVAILABLE_BOOKS: string[] = [
  // 'calculus-vol1',  // Coming soon
  // 'calculus-vol2',  // Coming soon
];

const contentId = BOOK_ID_MAP[bookId as string] || bookId;

// Check if book is available for preview
const isAvailable = AVAILABLE_BOOKS.includes(bookId as string);

let book;
let notFound = false;
let comingSoon = false;

if (!isAvailable) {
  comingSoon = true;
} else {
  try {
    const bookModule = await import(`../../../content/${contentId}/book.json`);
    book = bookModule.default;
  } catch (e) {
    notFound = true;
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={book ? `${book.title} - Mathematics Textbook` : 'Book not found'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{book ? book.title : 'Book Not Found'}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link 
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" 
      rel="stylesheet" 
    />
  </head>
  <body>
    {comingSoon ? (
      <div class="min-h-screen bg-gray-50 flex items-center justify-center">
        <div class="text-center">
          <div class="mb-6">
            <span class="inline-block bg-amber-100 text-amber-700 px-4 py-2 rounded-full text-lg font-medium">
              Coming Soon
            </span>
          </div>
          <h1 class="text-3xl font-bold text-gray-900 mb-4">This textbook is not yet available</h1>
          <p class="text-gray-600 mb-8 max-w-md mx-auto">
            We're putting the finishing touches on this textbook. Check back soon for the full preview.
          </p>
          <a href="/" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
            ← Back to Catalog
          </a>
        </div>
      </div>
    ) : notFound ? (
      <div class="min-h-screen bg-gray-50 flex items-center justify-center">
        <div class="text-center">
          <h1 class="text-2xl font-bold text-gray-900 mb-4">Book Not Found</h1>
          <a href="/" class="text-blue-600 hover:text-blue-800">
            ← Back to Catalog
          </a>
        </div>
      </div>
    ) : (
      <BookDetail book={book} bookId={contentId} client:only="react" />
    )}
  </body>
</html>
