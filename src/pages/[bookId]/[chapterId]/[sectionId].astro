---
/**
 * Section page — College Mathematics reader.
 *
 * Stripped from the original Axiom multi-book / dual-edition route:
 *   - No hostname-based edition detection
 *   - No access gating (Clay's call)
 *   - No embed/LTI mode (overkill for College Math v1)
 *   - Single book; bookId is always 'college-math'
 */
export const prerender = false;
import ReaderLayout from '../../../layouts/ReaderLayout.astro';
import { ReaderContent } from '../../../components/reader/ReaderContent';

const { bookId, chapterId, sectionId } = Astro.params;

// Dynamic imports — sections live at content/{bookId}/{chapterId}/{sectionId}.json
let book: any, section: any;
let notFound = false;

try {
    const bookModule = await import(`../../../../content/${bookId}/book.json`);
    book = bookModule.default;
    const sectionModule = await import(`../../../../content/${bookId}/${chapterId}/${sectionId}.json`);
    section = sectionModule.default;
} catch (e) {
    notFound = true;
}

// Filter exercise-related blocks out of the body content. Exercises
// live on a dedicated /exercises sub-page so the main section reads
// like a textbook chapter and the practice problems get their own
// "page-turn." Mirror the filter logic in [sectionId]/exercises.astro.
const isExerciseBlock = (b: any) => {
    if (!b) return false;
    if (b.type === 'exercise') return true;
    if (b.type === 'heading' && (b.text || '').toLowerCase().trim() === 'exercises') return true;
    if (b.type === 'paragraph' && (b.text || '').includes('cm-tx-exercises')) return true;
    return false;
};
const bodyContent = (section?.content || []).filter((b: any) => !isExerciseBlock(b));
const hasExercises = (section?.content || []).some(isExerciseBlock);

// Build prev/next navigation
let prevSection = null;
let nextSection = null;
if (book && section) {
    const allSections: Array<{
        chapter: number; section: number;
        chapterId: string; sectionId: string; title: string;
    }> = [];
    for (const ch of book.chapters) {
        for (const sec of ch.sections) {
            allSections.push({
                chapter: ch.number, section: sec.number,
                chapterId: ch.id, sectionId: sec.id, title: sec.title,
            });
        }
    }
    const currentIndex = allSections.findIndex(
        (s) => s.chapterId === chapterId && s.sectionId === sectionId
    );
    if (currentIndex > 0) prevSection = allSections[currentIndex - 1];
    if (currentIndex < allSections.length - 1) nextSection = allSections[currentIndex + 1];
}
---

{notFound ? (
    <html lang="en">
        <head>
            <meta charset="UTF-8" />
            <title>Section Not Found</title>
            <link rel="stylesheet" href="/src/styles/global.css" />
        </head>
        <body class="min-h-screen flex items-center justify-center" style="background: var(--ax-bg); color: var(--ax-text);">
            <div class="text-center p-8">
                <h1 class="text-2xl font-bold mb-4" style="color: var(--ax-text);">Section Not Found</h1>
                <p class="mb-4" style="color: var(--ax-text-secondary);">
                    Could not find: /{bookId}/{chapterId}/{sectionId}
                </p>
                <a href="/" style="color: var(--ax-violet); text-decoration: underline;">
                    ← Back to cover
                </a>
            </div>
        </body>
    </html>
) : (
    <ReaderLayout
        title={`${section.title} — ${book.title}`}
        book={book}
        bookId={bookId}
        currentChapter={section.chapter}
        currentSection={section.section}
        sectionTitle={section.title}
        prevSection={prevSection}
        nextSection={nextSection}
    >
        <article class="reader-content">
            <div class="section-hero">
                <span class="section-number">{section.chapter}.{section.section}</span>
                <h1 class="section-title">
                    {section.chapter}.{section.section}&ensp;{section.title}
                </h1>
                {section.deck && (
                    <p class="cm-section-opener">{section.deck}</p>
                )}
                <div class="section-meta" style="display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem; font-family: var(--ax-font-sans); font-size: 0.8rem; color: var(--ax-text-muted);">
                    <span>{Math.max(1, Math.round(JSON.stringify(section.content).length / 1200))} min read</span>
                    <span style="opacity: 0.3;">·</span>
                    <span>{section.content?.filter((b: any) => b.type === 'example').length || 0} examples</span>
                </div>
            </div>
            <ReaderContent
                content={bodyContent}
                epigraph={section.epigraph}
                marginNotes={section.marginNotes}
                chapter={section.chapter}
                section={section.section}
                objectives={section.objectives}
                bookId={bookId}
                client:only="react"
            />

            {hasExercises && (
                <div
                    class="mt-12 p-6 rounded"
                    style="border: 1px solid var(--ax-border); background: var(--ax-surface); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;"
                >
                    <div style="font-family: var(--ax-font-serif); color: var(--ax-text);">
                        <div style="font-family: var(--ax-font-sans); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; color: var(--ax-ex-accent); text-transform: uppercase; margin-bottom: 0.25rem;">
                            End of Section {section.chapter}.{section.section}
                        </div>
                        <div style="font-size: 1.05rem; line-height: 1.4;">
                            Ready to practice? Try the exercises for this section.
                        </div>
                    </div>
                    <a
                        href={`/${bookId}/${chapterId}/${sectionId}/exercises`}
                        style="display: inline-block; padding: 0.6rem 1.2rem; border-radius: 6px; background: var(--ax-violet); color: white; font-family: var(--ax-font-sans); font-weight: 600; text-decoration: none; font-size: 0.95rem; white-space: nowrap;"
                    >
                        Continue to exercises →
                    </a>
                </div>
            )}
        </article>
    </ReaderLayout>
)}
