---
export const prerender = false;
import ReaderLayout from '../../../layouts/ReaderLayout.astro';
import { ReaderContent } from '../../../components/reader/ReaderContent';

// Get params from URL
const { bookId, chapterId, sectionId } = Astro.params;

// Dynamic imports for content
let book, section;
let notFound = false;

try {
  // Load book metadata
  const bookModule = await import(`../../../../content/${bookId}/book.json`);
  book = bookModule.default;
  
  // Load section content
  const sectionModule = await import(`../../../../content/${bookId}/${chapterId}/${sectionId}.json`);
  section = sectionModule.default;
} catch (e) {
  notFound = true;
}

// Get prev/next navigation
let prevSection = null;
let nextSection = null;

if (book && section) {
  const allSections: Array<{chapter: number, section: number, chapterId: string, sectionId: string, title: string}> = [];
  
  for (const ch of book.chapters) {
    for (const sec of ch.sections) {
      allSections.push({
        chapter: ch.number,
        section: sec.number,
        chapterId: ch.id,
        sectionId: sec.id,
        title: sec.title
      });
    }
  }
  
  const currentIndex = allSections.findIndex(
    s => s.chapterId === chapterId && s.sectionId === sectionId
  );
  
  if (currentIndex > 0) {
    prevSection = allSections[currentIndex - 1];
  }
  if (currentIndex < allSections.length - 1) {
    nextSection = allSections[currentIndex + 1];
  }
}

// Map for catalog links
const catalogId = bookId === 'vol1' ? 'calculus-vol1' : bookId;
---

{notFound ? (
  <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <title>Section Not Found</title>
      <link rel="stylesheet" href="/src/styles/global.css" />
    </head>
    <body class="min-h-screen bg-atlas-cream flex items-center justify-center">
      <div class="text-center">
        <h1 class="text-2xl font-bold text-atlas-deep mb-4">Section Not Found</h1>
        <p class="text-atlas-secondary mb-4">
          Could not find: /{bookId}/{chapterId}/{sectionId}
        </p>
        <a href="/" class="text-atlas-teal hover:text-atlas-teal-dark flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Home
        </a>
      </div>
    </body>
  </html>
) : (
  <ReaderLayout 
    title={`${section.title} - ${book.title}`}
    book={book}
    currentChapter={section.chapter}
    currentSection={section.section}
    sectionTitle={section.title}
  >
    <article class="reader-content">
      <!-- Section Title -->
      <h1 class="section-title">
        {section.chapter}.{section.section}&ensp;{section.title}
      </h1>
      
      <!-- Main Content with Brand-Aware Rendering -->
      <ReaderContent 
        content={section.content}
        epigraph={section.epigraph}
        marginNotes={section.marginNotes}
        chapter={section.chapter}
        section={section.section}
        objectives={section.objectives}
        client:only="react"
      />
    </article>
  </ReaderLayout>
)}
