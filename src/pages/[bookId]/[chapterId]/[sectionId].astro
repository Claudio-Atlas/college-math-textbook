---
export const prerender = false;
import ReaderLayout from '../../../layouts/ReaderLayout.astro';
import { ReaderContent } from '../../../components/reader/ReaderContent';

// Get params from URL
const { bookId, chapterId, sectionId } = Astro.params;

// Dynamic imports for content
let book, section;
let notFound = false;

try {
  // Load book metadata
  const bookModule = await import(`../../../../content/${bookId}/book.json`);
  book = bookModule.default;
  
  // Load section content - try src-content first, then content
  try {
    const sectionModule = await import(`../../../../src-content/calculus-vol1/${chapterId}/${sectionId}.json`);
    section = sectionModule.default;
  } catch {
    const sectionModule = await import(`../../../../content/${bookId}/${chapterId}/${sectionId}.json`);
    section = sectionModule.default;
  }
} catch (e) {
  notFound = true;
}

// Get prev/next navigation
let prevSection = null;
let nextSection = null;

if (book && section) {
  const allSections: Array<{chapter: number, section: number, chapterId: string, sectionId: string, title: string}> = [];
  
  for (const ch of book.chapters) {
    for (const sec of ch.sections) {
      allSections.push({
        chapter: ch.number,
        section: sec.number,
        chapterId: ch.id,
        sectionId: sec.id,
        title: sec.title
      });
    }
  }
  
  const currentIndex = allSections.findIndex(
    s => s.chapterId === chapterId && s.sectionId === sectionId
  );
  
  if (currentIndex > 0) {
    prevSection = allSections[currentIndex - 1];
  }
  if (currentIndex < allSections.length - 1) {
    nextSection = allSections[currentIndex + 1];
  }
}

// Map for catalog links
const catalogId = bookId === 'vol1' ? 'calculus-vol1' : bookId;
---

{notFound ? (
  <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <title>Section Not Found</title>
      <link rel="stylesheet" href="/src/styles/global.css" />
    </head>
    <body class="min-h-screen bg-atlas-cream flex items-center justify-center">
      <div class="text-center">
        <h1 class="text-2xl font-bold text-atlas-deep mb-4">Section Not Found</h1>
        <p class="text-atlas-secondary mb-4">
          Could not find: /{bookId}/{chapterId}/{sectionId}
        </p>
        <a href="/" class="text-atlas-teal hover:text-atlas-teal-dark flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Home
        </a>
      </div>
    </body>
  </html>
) : (
  <ReaderLayout 
    title={`${section.title} - ${book.title}`}
    book={book}
    currentChapter={section.chapter}
    currentSection={section.section}
    sectionTitle={section.title}
  >
    <!-- Back Navigation Bar -->
    <div class="bg-white border-b border-gray-200 px-4 sm:px-8 py-3">
      <div class="max-w-4xl mx-auto flex items-center justify-between">
        <a 
          href={`/catalog/${catalogId}`}
          class="text-gray-600 hover:text-gray-900 flex items-center gap-2 text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Table of Contents
        </a>
        <a 
          href="/"
          class="text-gray-600 hover:text-gray-900 flex items-center gap-2 text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Home
        </a>
      </div>
    </div>

    <article class="px-4 sm:px-8 py-6 max-w-4xl mx-auto">
      <!-- Section Title -->
      <h1 class="text-2xl sm:text-3xl font-bold text-atlas-deep mb-2">
        {section.chapter}.{section.section} {section.title}
      </h1>
      
      <!-- Main Content with Brand-Aware Rendering -->
      <ReaderContent 
        content={section.content}
        epigraph={section.epigraph}
        marginNotes={section.marginNotes}
        chapter={section.chapter}
        section={section.section}
        objectives={section.objectives}
        client:only="react"
      />
      
      <!-- Navigation -->
      <nav class="mt-12 pt-8 border-t border-atlas-border">
        <div class="flex justify-between text-sm sm:text-base mb-6">
          {prevSection ? (
            <a 
              href={`/${bookId}/${prevSection.chapterId}/${prevSection.sectionId}`}
              class="text-atlas-teal hover:text-atlas-teal-dark flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              <span class="hidden sm:inline">{prevSection.chapter}.{prevSection.section}</span> {prevSection.title}
            </a>
          ) : (
            <span></span>
          )}
          {nextSection ? (
            <a 
              href={`/${bookId}/${nextSection.chapterId}/${nextSection.sectionId}`}
              class="text-atlas-teal hover:text-atlas-teal-dark flex items-center gap-2 text-right"
            >
              <span class="hidden sm:inline">{nextSection.chapter}.{nextSection.section}</span> {nextSection.title}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ) : (
            <span></span>
          )}
        </div>
        
        <!-- Back to TOC button -->
        <div class="text-center">
          <a 
            href={`/catalog/${catalogId}`}
            class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg text-gray-700 text-sm transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            View Table of Contents
          </a>
        </div>
      </nav>
    </article>
  </ReaderLayout>
)}
