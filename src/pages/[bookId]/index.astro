---
/**
 * Book landing page — College Mathematics.
 *
 * Routes:   /[bookId]   (e.g. /college-math)
 *
 * Shows a card grid of all chapters, each linking to its
 * chapter page at /[bookId]/[chapterId]. The per-chapter
 * section list lives on the chapter page, not here — this
 * page is a compact "all chapters at a glance" view.
 */
export const prerender = false;
import '../../styles/global.css';

const { bookId } = Astro.params;

let book: any = null;
let notFound = false;

try {
    const bookModule = await import(`../../../content/${bookId}/book.json`);
    book = bookModule.default;
} catch (e) {
    notFound = true;
}
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{notFound ? 'Book Not Found' : `${book.title} — Companion Textbook`}</title>
</head>
<body class="min-h-screen" style="background: var(--ax-bg); color: var(--ax-text);">
    {notFound ? (
        <div class="flex items-center justify-center min-h-screen">
            <div class="text-center">
                <h1 class="text-2xl font-bold mb-4">Book Not Found</h1>
                <a href="/" style="color: var(--ax-violet);">← Back to cover</a>
            </div>
        </div>
    ) : (
        <div class="cm-book-landing">
            <header class="cm-book-hero">
                <a href="/" class="cm-back-link">← Cover</a>
                <div class="cm-book-eyebrow">Table of Contents</div>
                <h1 class="cm-book-title">{book.title}</h1>
                {book.subtitle && <p class="cm-book-sub">{book.subtitle}</p>}
                {book.author && <p class="cm-book-byline">by {book.author}</p>}
            </header>

            <section class="cm-chapter-grid">
                {book.chapters.map((chapter: any) => (
                    <a href={`/${bookId}/${chapter.id}`} class="cm-chapter-card">
                        <div class="cm-chapter-card-head">
                            <span class="cm-chapter-card-num">Ch&nbsp;{String(chapter.number).padStart(2, '0')}</span>
                            <span class="cm-chapter-card-count">{chapter.sections.length} sections</span>
                        </div>
                        <h2 class="cm-chapter-card-title">{chapter.title}</h2>
                        {chapter.desc && (
                            <p class="cm-chapter-card-desc">{chapter.desc}</p>
                        )}
                        <span class="cm-chapter-card-cta">Read chapter →</span>
                    </a>
                ))}
            </section>
        </div>
    )}
</body>
</html>
