---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

export const prerender = false;
const host = Astro.request.headers.get('host') || 'localhost';
const isMeridian = host.includes('meridian');
const brandName = isMeridian ? 'Meridian Math' : 'Atlas Classical Press';
const domain = isMeridian ? 'meridian-math.org' : 'atlasclassicalpress.com';
const contactEmail = 'contact@onyxenterprises.org';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${brandName} Terms of Service`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Terms of Service — {brandName}</title>
    <ClientRouter />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('ax-theme');
        if (t === 'light' || t === 'dark') {
          document.documentElement.setAttribute('data-theme', t);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body class="bg-[var(--bg-primary)] text-[var(--text-primary)]">
    <div class="max-w-3xl mx-auto px-6 py-16">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-[var(--text-secondary)] hover:text-[#8B5CF6] transition-colors mb-10 group">
        <span class="group-hover:-translate-x-1 transition-transform">&larr;</span> Back to Home
      </a>
      
      <div class="mb-12 pb-8 border-b border-[var(--text-secondary)]/10">
        <h1 class="text-4xl font-bold mb-3 bg-gradient-to-r from-[#8B5CF6] to-[#14B8A6] bg-clip-text text-transparent">Terms of Service</h1>
        <p class="text-sm text-[var(--text-secondary)]">Last updated: March 6, 2026</p>
      </div>

      <div class="prose prose-invert max-w-none space-y-8 text-[var(--text-secondary)] leading-relaxed">
        <h2 class="text-xl font-semibold text-[var(--text-primary)]">1. Acceptance of Terms</h2>
        <p>By accessing or using {brandName} ("the Platform"), operated by Onyx Enterprises, LLC, you agree to be bound by these Terms of Service. If you are using the Platform on behalf of an educational institution, you represent that you have the authority to bind that institution to these terms.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">2. Description of Services</h2>
        <p>{brandName} provides complete mathematics education programs including:</p>
        <ul class="list-disc pl-6 space-y-1">
          <li>Digital textbooks with interactive content</li>
          <li>Video walkthrough lessons</li>
          <li>Practice problems with auto-grading</li>
          <li>AI-powered personal tutoring</li>
          <li>Student progress tracking and analytics</li>
          <li>Instructor dashboards and course management tools</li>
        </ul>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">3. Accounts</h2>
        <p>Some features require an account. You are responsible for maintaining the confidentiality of your login credentials. You agree to notify us immediately of any unauthorized use of your account.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">4. Institutional Agreements</h2>
        <p>Schools and districts that adopt our programs may be subject to additional terms outlined in a separate institutional agreement. In the event of a conflict, the institutional agreement takes precedence over these general terms.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">5. Intellectual Property</h2>
        <p>All content on the Platform, including textbooks, exercises, videos, illustrations, and software, is owned by {brandName} or its licensors and is protected by copyright law. You may not reproduce, distribute, or create derivative works from our content without written permission, except as permitted for personal educational use.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">6. Acceptable Use</h2>
        <p>You agree not to:</p>
        <ul class="list-disc pl-6 space-y-1">
          <li>Copy, redistribute, or sell our content</li>
          <li>Attempt to reverse-engineer the Platform or its AI features</li>
          <li>Use the Platform to generate content that violates any law</li>
          <li>Interfere with the Platform's operation or other users' access</li>
          <li>Share account credentials with unauthorized users</li>
        </ul>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">7. AI Tutoring Disclaimer</h2>
        <p>Our AI tutor is designed to assist students with mathematics learning. While we strive for accuracy, AI-generated responses may occasionally contain errors. The AI tutor is a supplemental tool and does not replace professional instruction. {brandName} is not liable for decisions made based on AI tutor output.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">8. Pricing and Payment</h2>
        <p>Pricing for individual and institutional access is available on our website or through direct consultation. All fees are non-refundable unless otherwise stated in an institutional agreement. We reserve the right to change pricing with 30 days notice.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">9. Availability and Modifications</h2>
        <p>We strive to maintain continuous access to the Platform but do not guarantee uninterrupted service. We may modify, update, or discontinue features at any time. For institutional customers, we will provide reasonable notice of material changes.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">10. Limitation of Liability</h2>
        <p>To the maximum extent permitted by law, {brandName} and Onyx Enterprises, LLC shall not be liable for any indirect, incidental, special, or consequential damages arising from your use of the Platform. Our total liability shall not exceed the amount you paid us in the 12 months preceding the claim.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">11. Termination</h2>
        <p>We may suspend or terminate your access to the Platform if you violate these terms. Upon termination, your right to use the Platform ceases immediately. Provisions that by their nature should survive termination will remain in effect.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">12. Governing Law</h2>
        <p>These terms are governed by the laws of the State of Arizona. Any disputes will be resolved in the courts of Maricopa County, Arizona.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">13. Changes to These Terms</h2>
        <p>We may update these terms from time to time. Continued use of the Platform after changes constitutes acceptance of the updated terms.</p>

        <h2 class="text-xl font-semibold text-[var(--text-primary)]">14. Contact Us</h2>
        <p>Questions about these terms? Contact us at <a href={`mailto:${contactEmail}`} class="text-blue-400 hover:underline">{contactEmail}</a>.</p>
      </div>
    </div>
  </body>
</html>
