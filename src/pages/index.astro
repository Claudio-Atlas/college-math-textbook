---
/**
 * College Mathematics — cover / landing page.
 *
 * Single-book reader (no multi-book catalog). One CTA goes to the
 * first chapter / first section.
 */
import '../styles/global.css';
const author = 'Clayton Ragsdale';
const title = 'College Mathematics';
const subtitle = 'A companion textbook';
const startUrl = '/college-math';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            background: var(--ax-bg);
            color: var(--ax-text);
            font-family: var(--ax-font-serif);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .cover {
            max-width: 32rem;
            padding: 4rem 2rem;
            text-align: center;
        }
        .cover-eyebrow {
            font-family: var(--ax-font-sans);
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--ax-violet);
            margin-bottom: 1.5rem;
        }
        .cover-title {
            font-family: var(--ax-font-sans);
            font-size: 3.5rem;
            font-weight: 700;
            letter-spacing: -0.025em;
            line-height: 1.05;
            margin: 0 0 0.75rem;
            color: var(--ax-text);
        }
        .cover-sub {
            font-family: var(--ax-font-serif);
            font-style: italic;
            font-size: 1.125rem;
            color: var(--ax-text-secondary);
            margin: 0 0 2rem;
        }
        .cover-byline {
            font-family: var(--ax-font-sans);
            font-size: 0.875rem;
            color: var(--ax-text-secondary);
            margin: 0 0 3rem;
        }
        .cover-cta {
            display: inline-block;
            padding: 0.875rem 1.75rem;
            background: var(--ax-violet);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-family: var(--ax-font-sans);
            font-size: 0.95rem;
            font-weight: 600;
            transition: background 150ms ease-out, transform 80ms ease-out;
        }
        .cover-cta:hover { background: var(--ax-violet-hover); }
        .cover-cta:active { transform: scale(0.97); }
        .cover-rule {
            width: 4rem;
            height: 2px;
            background: var(--ax-violet);
            opacity: 0.4;
            margin: 0 auto 2.5rem;
            border-radius: 1px;
        }
    </style>
</head>
<body>
    <div class="cover">
        <div class="cover-eyebrow">Companion Textbook</div>
        <h1 class="cover-title">{title}</h1>
        <p class="cover-sub">{subtitle}</p>
        <div class="cover-rule"></div>
        <p class="cover-byline">by {author}</p>
        <a class="cover-cta" href={startUrl}>Start reading →</a>
    </div>
</body>
</html>
