---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { HomePage } from '../components/home/HomePage';

export const prerender = false;
const host = Astro.request.headers.get('host') || 'localhost';
const forceEdition = host.includes('meridian') ? 'meridian' as const : 'atlas' as const;
const pageTitle = forceEdition === 'meridian' ? 'Meridian Press — Mathematics Textbooks' : 'Atlas Classical Press — Mathematics Textbooks';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Mathematics textbooks for classical and modern education" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <ClientRouter />
    
    <!-- Fonts loaded via global.css (Inter + Source Serif 4) -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('ax-theme');
        if (t === 'light' || t === 'dark') {
          document.documentElement.setAttribute('data-theme', t);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <HomePage forceEdition={forceEdition} client:only="react" />
  </body>
</html>
