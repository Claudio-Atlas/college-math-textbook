---
export const prerender = false;
import EmbedLayout from '../../layouts/EmbedLayout.astro';
import { ReaderContent } from '../../components/reader/ReaderContent';
import { isAccessGranted } from '../../lib/access';

/**
 * Embed route: /e/{bookId}/{chapterId}/{sectionId}/{accessKey}
 * 
 * Canvas-safe URL — the access key is part of the path, not a query param.
 * Canvas HTML sanitizer strips query params and hash fragments from external links,
 * but cannot modify URL path segments.
 * 
 * Example: /e/precalculus/ch02/sec01/PH95VEGwytmm33pB9PEaxf0OQb-aBa7zVjerf64vxX8
 */

const path = Astro.params.path || '';
const segments = path.split('/');

// Parse: bookId/chapterId/sectionId/accessKey
const bookId = segments[0] || '';
const chapterId = segments[1] || '';
const sectionId = segments[2] || '';
const accessKey = segments[3] || '';

const host = Astro.request.headers.get('host') || 'localhost';
const edition = host.includes('meridian') ? 'secular' : 'christian';

// Load content
let book: any, section: any;
let notFound = false;

try {
  const bookModule = await import(`../../../content/${bookId}/book.json`);
  book = bookModule.default;
  const sectionModule = await import(`../../../content/${bookId}/${chapterId}/${sectionId}.json`);
  section = sectionModule.default;
} catch (e) {
  notFound = true;
}

// Check access
const granted = isAccessGranted(chapterId, sectionId, accessKey, '', host);
---

{notFound ? (
  <html lang="en">
    <head><meta charset="UTF-8" /><title>Not Found</title></head>
    <body style="font-family: system-ui; padding: 50px; text-align: center;">
      <h1>Section Not Found</h1>
      <p>Could not find the requested section.</p>
      <a href="https://meridian-math.org">← Back to Meridian Press</a>
    </body>
  </html>

) : !granted ? (
  <html lang="en">
    <head><meta charset="UTF-8" /><title>Access Required</title></head>
    <body style="font-family: system-ui; padding: 50px; text-align: center;">
      <h1>🔒 Access Required</h1>
      <p>This content is available through your course's learning management system.</p>
      <a href="https://meridian-math.org/precalculus/ch01/sec01">Preview Section 1.1 Free →</a>
    </body>
  </html>

) : (
  <EmbedLayout
    title={`${section.title} - ${book.title}`}
    bookId={bookId}
    currentChapter={section.chapter}
    currentSection={section.section}
    sectionTitle={section.title}
  >
    <article class="reader-content">
      <div class="section-hero">
        <h1 class="section-title">
          {section.chapter}.{section.section}&ensp;{section.title}
        </h1>
        <div class="section-meta" style="display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem; font-family: var(--ax-font-sans); font-size: 0.8rem; color: var(--ax-text-muted);">
          <span>{Math.max(1, Math.round(JSON.stringify(section.content).length / 1200))} min read</span>
          <span style="opacity: 0.3;">·</span>
          <span>{section.content?.filter((b: any) => b.type === 'example').length || 0} examples</span>
          <span style="opacity: 0.3;">·</span>
          <span>{section.content?.filter((b: any) => b.type === 'definition').length || 0} definitions</span>
        </div>
      </div>
      <ReaderContent 
        content={section.content}
        epigraph={section.epigraph}
        marginNotes={section.marginNotes}
        chapter={section.chapter}
        section={section.section}
        objectives={section.objectives}
        bookId={bookId}
        edition={edition}
        client:only="react"
      />
    </article>
  </EmbedLayout>
)}
