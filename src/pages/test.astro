---
import ReaderLayout from '../layouts/ReaderLayout.astro';
import { ContentRenderer } from '../components/reader/ContentRenderer';

// Load book metadata and section content
import bookData from '../../content/vol1/book.json';
import sectionData from '../../content/vol1/ch01/sec01.json';

const section = sectionData;
const book = bookData;
---

<ReaderLayout 
  title={`${section.title} - ${book.title}`}
  book={book}
  currentChapter={section.chapter}
  currentSection={section.section}
  sectionTitle={section.title}
>
  <article class="px-4 sm:px-8 py-6 max-w-4xl mx-auto">
    <!-- Section Title -->
    <h1 class="text-2xl sm:text-3xl font-bold mb-2" style="color: var(--ax-text);">
      {section.chapter}.{section.section} {section.title}
    </h1>
    
    <!-- Epigraph -->
    {section.epigraph && (
      <blockquote class="my-8 pl-6 border-l-4 italic" style="border-color: var(--ax-violet); color: var(--ax-text-secondary);">
        <p class="mb-2">{section.epigraph.text}</p>
        <cite class="text-sm not-italic">— {section.epigraph.reference}</cite>
      </blockquote>
    )}
    
    <!-- Learning Objectives -->
    {section.objectives && section.objectives.length > 0 && (
      <div class="my-8 p-4 sm:p-6 rounded-lg" style="background: var(--ax-thm-bg); border: 1px solid var(--ax-thm-accent); border-radius: var(--ax-card-radius);">
        <h2 class="text-lg font-semibold mb-4" style="color: var(--ax-thm-accent);">Learning Objectives</h2>
        <ul class="space-y-2">
          {section.objectives.map((obj: string, i: number) => (
            <li class="flex items-start gap-2 text-sm sm:text-base">
              <span class="font-semibold whitespace-nowrap" style="color: var(--ax-thm-accent);">
                {section.chapter}.{section.section}.{i + 1}
              </span>
              <span>{obj}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
    
    <!-- Main Content -->
    <ContentRenderer content={section.content} client:only="react" />
    
    <!-- Navigation -->
    <nav class="mt-12 pt-8 flex justify-between text-sm sm:text-base" style="border-top: 1px solid var(--ax-border);">
      <a href="/" class="hover:underline" style="color: var(--ax-violet);">
        ← Previous Section
      </a>
      <a href="/" class="hover:underline" style="color: var(--ax-violet);">
        Next Section →
      </a>
    </nav>
  </article>
</ReaderLayout>
