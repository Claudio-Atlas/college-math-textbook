---
import '../styles/global.css';

interface Props {
  title: string;
  bookTitle?: string;
  sectionTitle?: string;
}

const { title, bookTitle, sectionTitle } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Axiom Reader - Mathematics Textbooks" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    
    <!-- MathJax is loaded by better-react-mathjax in ContentRenderer -->
  </head>
  <body class="min-h-screen bg-atlas-cream">
    <!-- Header -->
    {(bookTitle || sectionTitle) && (
      <header class="reader-header sticky top-0 z-50">
        <div class="flex items-center gap-3">
          {bookTitle && (
            <a href="/" class="text-white/80 hover:text-white text-sm">
              ← {bookTitle}
            </a>
          )}
          {sectionTitle && (
            <h1 class="text-lg font-semibold">{sectionTitle}</h1>
          )}
        </div>
      </header>
    )}
    
    <!-- Main content -->
    <main>
      <slot />
    </main>
  </body>
</html>
