---
import '../styles/global.css';
import { Sidebar } from '../components/reader/Sidebar';

interface Section {
  id: string;
  number: number;
  title: string;
  slug: string;
}

interface Chapter {
  id: string;
  number: number;
  title: string;
  sections: Section[];
}

interface Book {
  id: string;
  title: string;
  chapters: Chapter[];
}

interface Props {
  title: string;
  book?: Book;
  currentChapter?: number;
  currentSection?: number;
  sectionTitle?: string;
}

const { title, book, currentChapter, currentSection, sectionTitle } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Axiom Reader - Mathematics Textbooks" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-atlas-cream">
    <!-- Skip Link for Accessibility -->
    <a 
      href="#main-content" 
      class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-50 focus:bg-atlas-deep focus:text-white focus:px-4 focus:py-2"
    >
      Skip to main content
    </a>

    <!-- Top Header (OpenStax style) -->
    {book && (
      <header class="bg-atlas-warm text-atlas-deep sticky top-0 z-40">
        <div class="px-4 py-3">
          <a href={`/${book.id}`} class="flex items-center gap-2 text-sm hover:opacity-80">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            {book.title}
          </a>
          {sectionTitle && (
            <p class="text-xl font-bold mt-1">{sectionTitle}</p>
          )}
        </div>
      </header>
    )}

    <div class="flex">
      <!-- Sidebar (icon rail + expandable panel) -->
      {book && (
        <aside class="sticky top-[72px] h-[calc(100vh-72px)] flex-shrink-0 z-30">
          <Sidebar 
            book={book}
            currentChapter={currentChapter}
            currentSection={currentSection}
            client:load
          />
        </aside>
      )}

      <!-- Main Content -->
      <main id="main-content" class="flex-1 min-w-0">
        <slot />
      </main>
    </div>
  </body>
</html>
