---
import '../styles/global.css';
import { Sidebar } from '../components/reader/Sidebar';
import { ReaderHeader } from '../components/reader/ReaderHeader';
import { ProgressBar } from '../components/reader/ProgressBar';
import { UpNextCard } from '../components/reader/UpNextCard';

interface Section {
  id: string;
  number: number;
  title: string;
  slug: string;
}

interface Chapter {
  id: string;
  number: number;
  title: string;
  sections: Section[];
}

interface Book {
  id: string;
  title: string;
  chapters: Chapter[];
}

interface NavInfo {
  chapterId: string;
  sectionId: string;
  chapter: number;
  section: number;
  title: string;
}

interface Props {
  title: string;
  book?: Book;
  bookId?: string;
  currentChapter?: number;
  currentSection?: number;
  sectionTitle?: string;
  chapterTitle?: string;
  prevSection?: NavInfo | null;
  nextSection?: NavInfo | null;
}

const { 
  title, book, bookId, 
  currentChapter, currentSection, 
  sectionTitle, chapterTitle,
  prevSection, nextSection 
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Axiom Reader — Mathematics Textbooks" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen" style={`background: var(--ax-bg); color: var(--ax-text);`}>
    <!-- Skip Link -->
    <a 
      href="#main-content" 
      class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-[100] focus:px-4 focus:py-2 focus:rounded"
      style="background: var(--ax-violet); color: white;"
    >
      Skip to main content
    </a>

    {book && (
      <>
        <!-- Header -->
        <ReaderHeader
          bookId={bookId || book.id}
          currentChapter={currentChapter}
          currentSection={currentSection}
          sectionTitle={sectionTitle}
          chapterTitle={chapterTitle}
          prevSection={prevSection}
          nextSection={nextSection}
          client:load
        />

        <!-- Progress Bar -->
        <ProgressBar client:load />

        <!-- Sidebar Overlay -->
        <Sidebar
          book={book}
          bookId={bookId || book.id}
          currentChapter={currentChapter}
          currentSection={currentSection}
          client:load
        />
      </>
    )}

    <!-- Main Content — always centered, never shifts -->
    <main id="main-content" class="w-full" style={`padding-top: ${book ? '50px' : '0'};`}>
      <slot />
    </main>

    {book && nextSection && (
      <UpNextCard
        bookId={bookId || book.id}
        nextSection={nextSection}
        client:load
      />
    )}

    <!-- Keyboard shortcuts -->
    <script is:inline>
      document.addEventListener('keydown', (e) => {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
        
        if (e.key === 't' && !e.metaKey && !e.ctrlKey) {
          e.preventDefault();
          window.dispatchEvent(new CustomEvent('toggle-sidebar'));
        }
        if (e.key === 'ArrowLeft' && !e.metaKey && !e.ctrlKey) {
          const prev = document.querySelector('[data-nav-prev]');
          if (prev) prev.click();
        }
        if (e.key === 'ArrowRight' && !e.metaKey && !e.ctrlKey) {
          const next = document.querySelector('[data-nav-next]');
          if (next) next.click();
        }
      });
    </script>
  </body>
</html>
